# ============================================================
# AgaramAi Server Environment Variables
# ============================================================
# Copy this file to .env and fill in your own values.
# NEVER commit the actual .env file to version control.
# ============================================================

# Server port (default: 5000)
PORT=5000

# AES-256 Encryption Key
# Used to encrypt contact email/message fields and admin username in JSON files.
# Must be exactly 64 hex characters (= 32 bytes).
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_KEY=your_64_char_hex_key_here

# JWT Secret for admin session tokens
# Used to sign and verify admin login tokens.
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=your_128_char_hex_key_here

# Production API URL (used by the React frontend to call the backend)
# Set this to your deployed backend URL (e.g. Render, Railway, etc.)
# Leave empty or omit for local development (Vite proxy handles it)
VITE_API_URL=https://your-backend.onrender.com
